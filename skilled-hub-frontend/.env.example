# Copy to .env and fill in. Never commit real keys.

# Builds:
#   npm run build       → Vite "production" mode (same as build:prod)
#   npm run build:dev   → "development" mode — loads .env.development if present
#   npm run build:prod  → explicit production mode — loads .env.production if present
# PWA display names live in public/manifest.webmanifest (edit there if you rebrand).

# Native Android wrapper (Capacitor): after changing web UI, run `npm run cap:sync`, build APK in Android Studio,
# then upload the signed APK to hosting at public/downloads/techflash-android.apk (see route /download).

# Live publishable key — required for production builds (set in CI/hosting too).
VITE_STRIPE_PUBLISHABLE_KEY=

# Test publishable key — used only when running `npm run dev` (overrides VITE_STRIPE_PUBLISHABLE_KEY in dev).
VITE_STRIPE_PUBLISHABLE_KEY_TEST=

# Google Maps JavaScript API (Maps JS + Geocoder for dashboard job pins). Optional locally; without it the dashboard falls back to an embed preview.
VITE_GOOGLE_MAPS_API_KEY=

# API base URL (optional — defaults by hostname)
VITE_API_BASE_URL=

# Production admin: path to demo on main site
VITE_DEMO_APP_URL=https://techflash.app/demo

# Demo API (used when browser path is /demo/*)
VITE_DEMO_API_BASE_URL=

# Force demo UI locally without /demo prefix
VITE_DEMO_MODE=
