<%# CTA button partial - use with: render 'user_mailer/cta_button', text: 'View Dashboard', url: frontend_url('/dashboard') %>
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-top: 24px;">
  <tr>
    <td>
      <a href="<%= url %>" target="_blank" rel="noopener" style="display: inline-block; padding: 14px 28px; font-size: 16px; font-weight: 700; color: #ffffff !important; text-decoration: none; background-color: #FE6711; border-radius: 12px; box-shadow: 0 4px 14px rgba(254, 103, 17, 0.35);">
        <%= text %>
      </a>
    </td>
  </tr>
</table>
