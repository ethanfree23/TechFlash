<!DOCTYPE html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for?(:title) ? yield(:title) : 'TechFlash' %></title>
    <!--[if mso]>
    <noscript>
      <xml>
        <o:OfficeDocumentSettings>
          <o:PixelsPerInch>96</o:PixelsPerInch>
        </o:OfficeDocumentSettings>
      </xml>
    </noscript>
    <![endif]-->
  </head>
  <body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background-color: #F7F7F7; -webkit-font-smoothing: antialiased;">
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background: linear-gradient(135deg, #F7F7F7 0%, #F7F7F7 60%, rgba(254, 103, 17, 0.08) 100%); background-color: #F7F7F7;">
      <tr>
        <td align="center" style="padding: 32px 16px;">
          <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width: 600px; width: 100%;">
            <!-- Header -->
            <tr>
              <td style="background-color: #ffffff; border-radius: 16px 16px 0 0; padding: 24px 32px; border-bottom: 3px solid #FE6711; box-shadow: 0 2px 8px rgba(0,0,0,0.04);">
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                  <tr>
                    <td>
                      <span style="font-size: 24px; font-weight: 800; color: #1a1a1a; letter-spacing: -0.02em;">TechFlash</span>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <!-- Content -->
            <tr>
              <td style="background-color: #ffffff; padding: 32px 40px; box-shadow: 0 4px 16px rgba(0,0,0,0.06);">
                <%= yield %>
              </td>
            </tr>
            <!-- Footer -->
            <tr>
              <td style="background-color: #ffffff; border-radius: 0 0 16px 16px; padding: 24px 40px; border-top: 1px solid #f0f0f0;">
                <p style="margin: 0; font-size: 14px; color: #6b7280;">— The TechFlash Team</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
